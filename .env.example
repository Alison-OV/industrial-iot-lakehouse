# Environment configuration for Industrial IoT Lakehouse project
ENV=DEV

# Datalake credentials (MinIO / Azure)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=your_admin_user
STORAGE_SECRET_KEY=your_secure_password

# Local absolute paths (replace with your own)
LOCAL_LANDING_PYTHON=data/landing/predictive_maintenance.csv
