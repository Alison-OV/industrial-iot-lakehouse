LOCAL_BRONZE_PATH=file:///TU_RUTA_LOCAL/data/delta/bronze/telemetry
LOCAL_SILVER_PATH=file:///TU_RUTA_LOCAL/data/delta/silver/telemetry_clean
LOCAL_GOLD_HEALTH_PATH=file:///TU_RUTA_LOCAL/data/delta/gold/agg_device_health
